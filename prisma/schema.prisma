generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ━━━ USER & AUTH ━━━
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String   // hashed
  phone         String?
  avatar        String?
  role          String   @default("user") // user, admin, super_admin
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  
  // User profile
  measurements  String?  // JSON: {bust, waist, hips, height, shoulder}
  address       String?  // JSON: {street, city, state, pincode, country}
  occasion      String?  // preferred occasion type
  
  // Encryption & Permissions
  permissions   String?  // JSON string storing granular permission flags for staff/admin users
  encryptedData String?  // End-to-end encrypted personal data (phone, address, measurements)
  dataIv        String?  // Initialization vector for AES encryption
  
  // Relations
  wishlist        WishlistItem[]
  orders          Order[]
  reviews         Review[]
  staffPermission StaffPermission?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, productId])
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  items         String   // JSON array of {productId, name, price, qty, size, customization}
  total         Float
  status        String   @default("pending") // pending, confirmed, shipped, delivered, cancelled
  paymentMethod String?  // razorpay, stripe, cod
  paymentStatus String   @default("pending") // pending, paid, failed, refunded
  paymentId     String?  // payment gateway transaction ID
  shippingAddr  String?  // JSON
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String?
  rating    Int
  title     String?
  content   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ━━━ INQUIRIES & APPOINTMENTS ━━━
model Inquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  occasion  String?
  message   String
  type      String   @default("general") // general, bespoke, appointment, product
  source    String?  // website, whatsapp, instagram
  status    String   @default("new") // new, contacted, converted, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  appointmentType String   // bridal, styling, custom
  occasion        String?
  preferredDate   String?
  preferredTime   String?
  message         String?
  status          String   @default("pending") // pending, confirmed, completed, cancelled
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ━━━ PRODUCTS ━━━
model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  category      String   // bridal-lehenga, designer-saree, festive, western-fusion, ready-to-wear, bespoke
  price         Float?
  priceType     String   @default("show") // show, inquire, range
  images        String   @default("[]") // JSON array of image URLs
  fabric        String?
  craftsmanship String?
  care          String?
  sizes         String?  // JSON array of available sizes
  customization String?  // JSON: available customization options
  deliveryDays  Int?
  featured      Boolean  @default(false)
  active        Boolean  @default(true)
  
  wishlist      WishlistItem[]
  reviews       Review[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ━━━ BLOG ━━━
model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String
  category      String   // bridal-style, lehenga-saree, wedding-trends, styling-tips, behind-craft, jaipur-fashion, celebrity, how-to-choose
  featuredImage String?
  author        String   @default("House of Shringarika")
  metaTitle     String?
  metaDesc      String?
  tags          String?  // JSON array
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ━━━ TESTIMONIALS & GALLERY ━━━
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?  // Bride, Client etc.
  content   String
  rating    Int      @default(5)
  image     String?
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String?
  category    String?  // bridal, festive, western, atelier, campaign
  imageUrl    String
  collection  String?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ━━━ SITE SETTINGS (Admin) ━━━
model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON string for complex values
}

// ━━━ STAFF PERMISSIONS ━━━
model StaffPermission {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Granular permissions
  canAccessDashboard    Boolean @default(true)
  canManageBlogs        Boolean @default(false)
  canManageProducts     Boolean @default(false)
  canViewInquiries      Boolean @default(false)
  canManageAppointments Boolean @default(false)
  canManageGallery      Boolean @default(false)
  canViewUsers          Boolean @default(false)  // super admin only
  canManageSettings     Boolean @default(false)  // super admin only
  canChangePassword     Boolean @default(true)   // can change own password

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ━━━ PAGE CONTENT MANAGEMENT ━━━
model PageContent {
  id        String   @id @default(cuid())
  page      String   // home, about, collections, bespoke, lookbook, blog, contact, appointments
  section   String   // hero, brand_story, collections_preview, bespoke_cta, lookbook_preview, testimonials, instagram, cta, etc.
  title     String?
  subtitle  String?
  content   String?  // JSON for complex content (buttons, links, etc.)
  imageUrl  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([page, section])
}

// ━━━ MEDIA UPLOADS ━━━
model MediaUpload {
  id          String   @id @default(cuid())
  title       String?
  description String?
  category    String?  // hero, gallery, product, blog, lookbook, campaign, banner
  imageUrl    String
  publicId    String?  // For cloud storage reference
  altText     String?
  tags        String?  // JSON array of tags
  uploadedBy  String?  // User ID
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ━━━ THEME CONFIGURATION ━━━
model ThemeConfig {
  id              String   @id @default(cuid())
  name            String   @unique  // e.g., "default", "dark", "bridal"
  label           String   // Display name
  primaryColor    String   @default("#B76E79")
  secondaryColor  String   @default("#E8D9C0")
  accentColor     String   @default("#B89840")
  backgroundColor String   @default("#F2EDE8")
  textColor       String   @default("#1A1A1A")
  cardColor       String   @default("#F7F3EF")
  borderColor     String   @default("#D4C2A5")
  fontFamily      String   @default("Cormorant Garamond")
  headingFont     String   @default("Playfair Display")
  bodyFont        String   @default("DM Sans")
  customCss       String?  // Additional custom CSS
  showParticles   Boolean  @default(true)
  showCursorEffect Boolean @default(true)
  active          Boolean  @default(false)  // Only one theme can be active
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ━━━ SOCIAL MEDIA LINKS ━━━
model SocialLink {
  id          String   @id @default(cuid())
  platform    String   @unique  // instagram, facebook, pinterest, youtube, twitter, linkedin, whatsapp
  url         String
  username    String?
  icon        String?  // Icon name or SVG
  showInFooter Boolean @default(true)
  showInHeader Boolean @default(false)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ━━━ AI REPORTS ━━━
model AIReport {
  id          String   @id @default(cuid())
  title       String
  type        String   // analytics, seo, content, social, performance, custom
  prompt      String   // The original prompt/request
  content     String   // The generated report content (markdown)
  metadata    String?  // JSON: additional data like charts, metrics
  generatedBy String   @default("AI Assistant")
  isBookmarked Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
